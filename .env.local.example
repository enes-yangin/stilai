# ----------------------------------------------------------------------------
# Bu dosyayı ".env.local" olarak kopyalayın ve anahtarlarınızı girin.
#   cp .env.local.example .env.local
# Tüm servisler ücretsiz katmana sahiptir (dağıtık, sıfır maliyet mimarisi).
# ----------------------------------------------------------------------------

# Sanal Giydirme (VTON) — Hugging Face Gradio (IDM-VTON + Leffa)
# Rate limit / CPU hatası yememek için VİRGÜLLE ayırarak BİRDEN ÇOK token ekleyin
# (Token Rotation): biri limite takılırsa otomatik sıradakine geçilir.
# https://huggingface.co/settings/tokens  ->  "Read" yetkili token(lar)
HF_TOKENS=hf_token1,hf_token2,hf_token3
# (Geriye dönük uyumluluk için tek token da desteklenir)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Kıyafet Analizi (Vision) — Google AI Studio / Gemini
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# OPTIONAL: model override (varsayılan: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Kombin Önerisi (LLM) — Groq
# https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPTIONAL: model override (varsayılan: llama3-8b-8192, fail-safe fallback'li)
# GROQ_MODEL=llama-3.1-8b-instant

# Hava durumu: Open-Meteo anahtarsız çalışır.

# Database (Prisma / SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Oturum güvenliği
NEXTAUTH_SECRET="gen-random-string-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
